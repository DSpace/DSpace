## E-mail sent by the healthcheck command to whomever is mentioned as -e parameter.
##
## Parameters: {0} is the output of healthcheck command
## See org.dspace.core.Email for information on the format of this file.
##
#set($mimetype = "text/html")
#set($subject = "${config.get('dspace.name')}: Repository healthcheck")
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>System Healthcheck Completed</title>
    <style>
        #parse("_email_common_styles")
        .output {
            background-color: #f9f9f9;
            padding: 20px;
            border-radius: 4px;
            margin: 20px 0;
            border-left: 4px solid #007cba;
            font-family: monospace;
            white-space: pre-wrap;
        }
    </style>
</head>
<body>
    <div class="container">
        <h2>System Healthcheck Completed</h2>

        <div class="info-box">
            <p>The healthcheck finished with the following output:</p>
        </div>

        <div class="output">
          ${params[0]}
        </div>
    </div>
</body>
</html>