## Rejection email message
##
## {0}  Title of submission
## {1}  Name of collection
## {2}  Name of the rejector
## {3}  Reason for the rejection
## {4}  Link to 'My DSpace' page
##
#set($mimetype = "text/html")
#set($subject = "${config.get('dspace.name')}: Submission Rejected")
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Submission Has Been Rejected</title>
    <style>
        #parse("_email_common_styles")
        .explanation {
            background-color: #fce4e4;
            padding: 20px;
            border-radius: 4px;
            margin: 20px 0;
            border-left: 4px solid #d32f2f;
        }
        .access-info {
            background-color: #e3f2fd;
            padding: 15px;
            border-radius: 4px;
            margin: 20px 0;
        }
    </style>
</head>
<body>
    <div class="container">
        <h2>Submission Rejected</h2>

        <div class="error-box">
            Your submission has been rejected by ${params[2]}
        </div>

        <div class="detail-box">
            <p><strong>You submitted:</strong> ${params[0]}</p>
            <p><strong>To collection:</strong> ${params[1]}</p>
        </div>

        <p><strong>with the following explanation:</strong></p>

        <div class="explanation">
            ${params[3]}
        </div>

        <div class="access-info">
            <p>Your submission has not been deleted. You can access it from your "My${config.get('dspace.shortname')}" page:</p>
            <p><a href="${params[4]}" class="button">View Submission</a></p>
            <p>${params[4]}</p>
        </div>

        <p class="signature">The ${config.get('dspace.name')} Team</p>
    </div>
</body>
</html>