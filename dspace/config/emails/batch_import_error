## Email sent to DSpace users when their batch import fails.
##
## Parameters: {0} the export error
##             {1} the URL to the feedback page
##
##
## See org.dspace.core.Email for information on the format of this file.
##
#set($mimetype = "text/html")
#set($subject = 'DSpace - The batch import was not completed.')
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Batch Import Failed</title>
    <style>
        #parse("_email_common_styles")
    </style>
</head>
<body>
    <div class="container">
        <p>The batch import you initiated from the DSpace UI was not completed, due to the following reason:</p>

        <div class="error-box">
            ${params[0]}
        </div>

        <p class="contact">For more information you may contact your system administrator:<br>
        ${params[1]}</p>

        <p class="signature">The DSpace Team</p>
    </div>
</body>
</html>