
## Email sent to DSpace users when they successfully batch import items.
##
## Parameters: {0} the filepath to the mapfile created by the batch import
##
##
## See org.dspace.core.Email for information on the format of this file.
##
#set($mimetype = "text/html")
#set($subject = 'DSpace - Batch import successfully completed')
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Batch Import Completed Successfully</title>
    <style>
        #parse("_email_common_styles")
        .file-path {
            background-color: #f1f8e9;
            padding: 15px;
            border-radius: 4px;
            margin: 20px 0;
            font-family: monospace;
            word-break: break-all;
        }
    </style>
</head>
<body>
    <div class="container">
        <h2>Batch Import Completed Successfully</h2>

        <div class="success-box">
            <p>The batch item import you initiated from the DSpace UI has completed successfully.</p>
        </div>

        <p>You may find the mapfile for the import in the following path:</p>

        <div class="file-path">
            ${params[0]}
        </div>

        <p class="signature">The DSpace Team</p>
    </div>
</body>
</html>