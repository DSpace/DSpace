## Item Archived email message
##
## {0}  Title of submission
## {1}  Name of collection
## {2}  handle
##
#set($mimetype = "text/html")
#set($subject = "${config.get('dspace.name')}: Submission Approved and Archived")
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Submission Has Been Accepted</title>
    <style>
        #parse("_email_common_styles")
        .identifier {
            background-color: #e3f2fd;
            padding: 20px;
            border-radius: 4px;
            margin: 20px 0;
            text-align: center;
            font-weight: bold;
            font-size: 1.1em;
            border: 2px dashed #2196f3;
        }
        .citation-note {
            background-color: #fff3e0;
            padding: 15px;
            border-radius: 4px;
            margin: 20px 0;
            border-left: 4px solid #ff9800;
        }
    </style>
</head>
<body>
    <div class="container">
        <h2>Submission Accepted</h2>

        <div class="success-box">
            Your submission has been accepted and archived in ${config.get('dspace.name')}!
        </div>

        <div class="detail-box">
            <p><strong>You submitted:</strong> ${params[0]}</p>
            <p><strong>To collection:</strong> ${params[1]}</p>
        </div>

        <p>Your submission has been assigned the following identifier:</p>

        <div class="identifier">
            <a href="${params[2]}">${params[2]}</a>
        </div>

        <div class="citation-note">
            <p><strong>Please use this identifier when citing your submission.</strong></p>
        </div>

        <p class="signature">Many thanks!<br><br>
        The ${config.get('dspace.name')} Team</p>
    </div>
</body>
</html>