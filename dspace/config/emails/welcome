## E-mail sent to a DSpace user after a new account is registered.
##
## See org.dspace.core.Email for information on the format of this file.
##
#set($mimetype = "text/html")
#set($subject = "Welcome new registered ${config.get('dspace.name')} user!")
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Account Registration Confirmation</title>
    <style>
        #parse("_email_common_styles")
    </style>
</head>
<body>
    <div class="container">
        <p>Thank you for registering an account. Your new account can be used immediately to subscribe to notices of new content arriving in collections of your choice.</p>

        <p>Your new account can also be granted privileges to submit new content, or to edit and/or approve submissions.</p>

        <p class="contact">If you need assistance with your account, please email ${config.get("mail.helpdesk")}.</p>

        <p class="signature">The ${config.get('dspace.name')} Team</p>
    </div>
</body>
</html>