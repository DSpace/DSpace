## Workflow curation task notification email message
##
## {0}  Title of submission
## {1}  Name of collection
## {2}  Submitter's name
## {3}  Name of task operating
## {4}  Task result
## {5}  Workflow action taken
##
#set($mimetype = "text/html")
#set($subject = "${config.get('dspace.name')}: Curation Task Report")
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Curation Task Completed</title>
    <style>
        #parse("_email_common_styles")
        .submission-info {
            background-color: #e8f4f8;
            padding: 15px;
            border-radius: 4px;
            margin: 20px 0;
        }
        .result {
            background-color: #f0f7ff;
            padding: 20px;
            border-radius: 4px;
            margin: 20px 0;
            border-left: 4px solid #007cba;
        }
        .action {
            background-color: #e3f2fd;
            padding: 15px;
            border-radius: 4px;
            margin: 20px 0;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="container">
        <h2>Curation Task Completed</h2>

        <div class="submission-info">
            <p><strong>Title:</strong> ${params[0]}<br>
            <strong>Collection:</strong> ${params[1]}<br>
            <strong>Submitted by:</strong> ${params[2]}</p>
        </div>

        <p>Curation task <strong>${params[3]}</strong> has been performed with the following result:</p>

        <div class="result">
            ${params[4]}
        </div>

        <div class="action">
            Action taken on the submission: ${params[5]}
        </div>

        <p class="signature">The ${config.get('dspace.name')} Team</p>
    </div>
</body>
</html>