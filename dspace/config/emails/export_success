## Email sent to DSpace users when they successfully export an item or collection.
##
## Parameters: {0} is expanded to a special URL
##             {1} configurable time (hours) an export file will be kept
##
## See org.dspace.core.Email for information on the format of this file.
##
#set($mimetype = "text/html")
#set($subject = "${config.get('dspace.name')}: Item export requested is ready for download")
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Item Export Request Success</title>
    <style>
        #parse("_email_common_styles")
        .button {
            background-color: #4caf50;
        }
    </style>
</head>
<body>
    <div class="container">
        <p>The item export you requested from the repository is now ready for download.</p>

        <p>You may download the compressed file using the following link:</p>

        <p><a href="${params[0]}" class="button">Download Export</a></p>

        <p>If you're unable to click the button, you can copy and paste the following link into your browser:</p>
        <p>${params[0]}</p>

        <div class="info-box">
            This file will remain available for at least ${params[1]} hours.
        </div>

        <p class="signature">The ${config.get('dspace.name')} Team</p>
    </div>
</body>
</html>