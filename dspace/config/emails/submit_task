## Workflow task email message
##
## {0}  Title of submission
## {1}  Name of collection
## {2}  submitter's name
## {3}  Description of task
## {4}  link to 'my DSpace' page
##
#set($mimetype = "text/html")
#set($subject = "${config.get('dspace.name')}: You have a new task")
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Item Submitted for Review</title>
    <style>
        #parse("_email_common_styles")
        .description {
            background-color: #f0f7ff;
            padding: 20px;
            border-radius: 4px;
            margin: 20px 0;
        }
    </style>
</head>
<body>
    <div class="container">
        <h2>New Item Submitted for Review</h2>

        <div class="info-box">
            A new item has been submitted and requires your attention.
        </div>

        <div class="detail-box">
            <div class="detail-item"><strong>Title:</strong> ${params[0]}</div>
            <div class="detail-item"><strong>Collection:</strong> ${params[1]}</div>
            <div class="detail-item"><strong>Submitted by:</strong> ${params[2]}</div>
        </div>

        <div class="description">
            ${params[3]}
        </div>

        <p>To claim this task, please visit your "My${config.get('dspace.shortname')}" page:</p>

        <p><a href="${params[4]}" class="button">Review Submission</a></p>
        <p>${params[4]}</p>

        <p class="signature">Many thanks!<br><br>
        The ${config.get('dspace.name')} Team</p>
    </div>
</body>
</html>