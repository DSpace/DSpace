## Registration notification email
##
## Parameters: {0} The name of the DSpace instance
##             {1} The URL of the DSpace instance
##             {2} Name:
##             {3} Email:
##             {4} Registration Date:
##
## See org.dspace.core.Email for information on the format of this file.
##
#set($mimetype = "text/html")
#set($subject = "${config.get('dspace.name')}: Registration Notification")
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New User Registration</title>
    <style>
        #parse("_email_common_styles")
    </style>
</head>
<body>
    <div class="container">
        <h2>New User Registration</h2>

        <div class="info-box">
            A new user has registered on ${params[0]} at ${params[1]}
        </div>

        <div class="detail-box">
            <div class="detail-item"><strong>Name:</strong> ${params[2]}</div>
            <div class="detail-item"><strong>Email:</strong> ${params[3]}</div>
            <div class="detail-item"><strong>Date:</strong> ${params[4]}</div>
        </div>

        <p class="signature">The ${config.get('dspace.name')} Team</p>
    </div>
</body>
</html>