<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:util="http://www.springframework.org/schema/util"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-2.5.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context-2.5.xsd http://www.springframework.org/schema/util http://www.springframework.org/schema/util/spring-util.xsd"
>

    <context:annotation-config />
    
    <!-- ================================================================================ -->
    <!-- CORE SERVICES                                                                    -->
    <!-- ================================================================================ -->
    
    <!-- Core service that orchestrates all item enhancement operations.
         Manages enhancement execution, deep mode processing, and affected item tracking. -->
    <bean id="org.dspace.content.enhancer.service.ItemEnhancerService"
        class="org.dspace.content.enhancer.service.impl.ItemEnhancerServiceImpl" />

    <!-- Utility service providing helper methods for virtual metadata manipulation.
         Used by RelatedEntityItemEnhancer to organize and compare virtual metadata states. -->
    <bean class="org.dspace.content.enhancer.impl.RelatedEntityItemEnhancerUtils" />

    <!-- ================================================================================ -->
    <!-- ENTITY TYPE LISTS                                                                -->
    <!-- ================================================================================ -->

    <!-- List of research output entity types that can receive virtual metadata from related entities.
         These are the "target" entities that will be enhanced with data from Person entities.
         Used by both department and ORCID enhancers below. -->
    <util:list id="researchOutputsEntityTypes">
        <value>Publication</value>
        <value>Product</value>
        <value>Patent</value>
    </util:list>

    <!-- ================================================================================ -->
    <!-- VIRTUAL METADATA ENHANCER BEANS                                                  -->
    <!-- Each bean defines one enhancement rule that copies specific metadata from        -->
    <!-- related entities to create virtual metadata fields on source items.              -->
    <!-- ================================================================================ -->

    <!-- DEPARTMENT ENHANCER
         Copies affiliation information from Person entities to research outputs.
         
         What it does:
         - Finds Person entities linked via dc.contributor.author or dc.contributor.editor
         - Copies person.affiliation.name values
         - Creates cris.virtual.department fields on the Publication/Product/Patent
         - Creates cris.virtualsource.department fields tracking source Person UUIDs
         
         Use case:
         - Enable faceted search by author affiliation/department
         - Generate institutional reports (publications by department)
         - Identify publications with authors from specific organizations
         
         Example result on a Publication:
         - cris.virtual.department = "Computer Science Department"
         - cris.virtualsource.department = "person-uuid-123" -->
    <bean class="org.dspace.content.enhancer.impl.RelatedEntityItemEnhancer" >
        <property name="sourceEntityTypes" ref="researchOutputsEntityTypes" />
        <property name="sourceItemMetadataFields">
            <list>
                <value>dc.contributor.author</value>   <!-- Authors of publications -->
                <value>dc.contributor.editor</value>   <!-- Editors of publications -->
            </list>
        </property>
        <property name="relatedItemMetadataFields">
            <list>
                <value>person.affiliation.name</value> <!-- Copy affiliation from Person entity -->
            </list>
        </property>
        <property name="virtualQualifier" value="department" />
    </bean>

    <!-- ORCID ENHANCER
         Copies ORCID identifiers from Person entities to research outputs.
         
         What it does:
         - Finds Person entities linked via dc.contributor.author or dc.contributor.editor
         - Copies person.identifier.orcid values
         - Creates cris.virtual.orcid fields on the Publication/Product/Patent
         - Creates cris.virtualsource.orcid fields tracking source Person UUIDs
         
         Use case:
         - Enable faceted search by author ORCID
         - Include author ORCIDs in metadata exports (DataCite, CrossRef, OAI-PMH)
         - Identify publications with authors missing ORCID identifiers (via placeholder values)
         - Support ORCID integration and validation workflows
         
         Example result on a Publication:
         - cris.virtual.orcid = "0000-0001-2345-6789"
         - cris.virtualsource.orcid = "person-uuid-123"
         
         Note: If a Person has no ORCID, a placeholder value (#PLACEHOLDER_PARENT_METADATA_VALUE#)
         is stored. When the Person later adds an ORCID, cascade updates will populate
         this field on all linked Publications. -->
    <bean class="org.dspace.content.enhancer.impl.RelatedEntityItemEnhancer" >
        <property name="sourceEntityTypes" ref="researchOutputsEntityTypes" />
        <property name="sourceItemMetadataFields">
            <list>
                <value>dc.contributor.author</value>   <!-- Authors of publications -->
                <value>dc.contributor.editor</value>   <!-- Editors of publications -->
            </list>
        </property>
        <property name="relatedItemMetadataFields">
            <list>
                <value>person.identifier.orcid</value> <!-- Copy ORCID from Person entity -->
            </list>
        </property>
        <property name="virtualQualifier" value="orcid" />
    </bean>

</beans>
