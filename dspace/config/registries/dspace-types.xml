<dspace-dc-types>

    <dspace-header>
        <title>DSpace Internal Types Registry</title>
    </dspace-header>

    <dc-schema>
        <name>dspace</name>
        <namespace>http://dspace.org/dspace</namespace>
    </dc-schema>

    <dc-type>
        <schema>dspace</schema>
        <element>process</element>
        <qualifier>filetype</qualifier>
        <scope_note></scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>agreements</element>
        <qualifier>end-user</qualifier>
        <scope_note>Stores whether the End User Agreement has been accepted by an EPerson. Valid values; true, false</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>agreements</element>
        <qualifier>cookies</qualifier>
        <scope_note>Stores the cookie preferences of an EPerson, as selected in last session. Value will be an array of cookieName/boolean pairs, specifying which cookies are allowed or not allowed.</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>entity</element>
        <qualifier>type</qualifier>
        <scope_note>Stores the type of Entity that a specific Item represents</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>relatedentity</element>
        <qualifier>type</qualifier>
        <scope_note>Stores the type of Entity that a specific Item represents when it is linked to another item</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>iiif</element>
        <qualifier>enabled</qualifier>
        <scope_note>Stores a boolean text value (true or false) to indicate if the iiif feature is enabled or not for the dspace object. If absent the value is derived from the parent dspace object</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>object</element>
        <qualifier>owner</qualifier>
        <scope_note>Used to support researcher profiles</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>orcid</element>
        <qualifier>scope</qualifier>
        <scope_note>Stores the scopes/authorizations granted by the user during authentication on ORCID</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>orcid</element>
        <qualifier>sync-mode</qualifier>
        <scope_note>Stores the synchronization with ORCID mode chosen by the user</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>orcid</element>
        <qualifier>sync-publications</qualifier>
        <scope_note>Stores the publication synchronization with ORCID preference chosen by the user</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>orcid</element>
        <qualifier>sync-fundings</qualifier>
        <scope_note>Stores the funding synchronization with ORCID preference chosen by the user</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>orcid</element>
        <qualifier>sync-profile</qualifier>
        <scope_note>Stores the profile synchronization with ORCID preference chosen by the user</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>orcid</element>
        <qualifier>authenticated</qualifier>
        <scope_note>Stores the timestamp related to the user authentication on ORCID</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>openalex</element>
        <qualifier>lastimport</qualifier>
        <scope_note>Stores the timestamp related to the last import from OpenAlex</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>openaire</element>
        <qualifier>lastimport</qualifier>
        <scope_note>Stores the timestamp related to the last import from OpenAIRE Graph</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>accessibility</element>
        <qualifier>settings</qualifier>
        <scope_note>Metadata field storing the user-configured accessibility settings values for the EPerson.</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>customurl</element>
        <qualifier/>
        <scope_note>Custom URL for DSpace entities (e.g. Person, Publication, etc).</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>customurl</element>
        <qualifier>old</qualifier>
        <scope_note>Previous custom URLs for DSpace entities, used for redirects and legacy support.</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>sourceId</element>
        <qualifier></qualifier>
        <scope_note>Used by the cris consumer to store the source that has originated the item</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>policy</element>
        <qualifier>eperson</qualifier>
        <scope_note>Default metadata for custom policies rule</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>policy</element>
        <qualifier>group</qualifier>
        <scope_note>Default metadata for custom policies rule</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>submission</element>
        <qualifier>definition</qualifier>
        <scope_note>Metadata to link a collection with a submission type</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>submission</element>
        <qualifier>definition-correction</qualifier>
        <scope_note>Metadata to link a collection with a correction submission type</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>workflow</element>
        <qualifier>name</qualifier>
        <scope_note>Metadata to link a collection with a workflow type</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>harvesting</element>
        <qualifier>email</qualifier>
        <scope_note>Email address for receiving OAI harvester notifications and status reports</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>harvesting</element>
        <qualifier>preTransform</qualifier>
        <scope_note>XSLT stylesheet for pre-processing harvested metadata before transformation</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>harvesting</element>
        <qualifier>postTransform</qualifier>
        <scope_note>XSLT stylesheet for post-processing harvested metadata after transformation</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>harvesting</element>
        <qualifier>itemValidationEnabled</qualifier>
        <scope_note>Boolean flag to enable validation of items during OAI harvesting process</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>harvesting</element>
        <qualifier>recordValidationEnabled</qualifier>
        <scope_note>Boolean flag to enable validation of OAI-PMH records during harvesting</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>harvesting</element>
        <qualifier>forceSynchronization</qualifier>
        <scope_note>Boolean flag to force synchronization of all harvested items regardless of changes</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>harvesting</element>
        <qualifier>ccAddress</qualifier>
        <scope_note>Carbon copy email addresses for OAI harvester notifications</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>identifier</element>
        <qualifier>gscholar</qualifier>
        <scope_note>Google Scholar identifier for indexing and citation tracking</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>workspace</element>
        <qualifier>shared</qualifier>
        <scope_note>Boolean flag indicating if collection workspace is shared among submitters</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>author</element>
        <qualifier>scopus-author-id</qualifier>
        <scope_note>Scopus Author ID for author disambiguation and profile linking</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>author</element>
        <qualifier>orcid</qualifier>
        <scope_note>ORCID (Open Researcher and Contributor ID) for persistent author identification</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>author</element>
        <qualifier>rid</qualifier>
        <scope_note>Researcher ID from academic or institutional identifier systems</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>legacyId</element>
        <qualifier></qualifier>
        <scope_note>Legacy identifier from previous repository systems for migration tracking</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>virtual</element>
        <qualifier>department</qualifier>
        <scope_note>Virtual metadata field holding department/affiliation value derived from linked Person entity</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>virtual</element>
        <qualifier>orcid</qualifier>
        <scope_note>Virtual metadata field holding ORCID value derived from linked Person entity</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>virtualsource</element>
        <qualifier>department</qualifier>
        <scope_note>Reference to the source Person entity UUID for virtual department metadata</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>virtualsource</element>
        <qualifier>orcid</qualifier>
        <scope_note>Reference to the source Person entity UUID for virtual ORCID metadata</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>cms</element>
        <qualifier>home-header</qualifier>
        <scope_note>Content Management System header content for the repository home page</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>cms</element>
        <qualifier>home-news</qualifier>
        <scope_note>Content Management System news section for the repository home page</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>cms</element>
        <qualifier>footer</qualifier>
        <scope_note>Content Management System footer content for the repository pages</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>customurl</element>
        <scope_note>Custom URL for the item to create user-friendly persistent links</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>customurl</element>
        <qualifier>old</qualifier>
        <scope_note>Previous custom URLs for the item used for redirects after URL changes</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>lastimport</element>
        <qualifier>ads</qualifier>
        <scope_note>Timestamp of the last import from the Astrophysics Data System (ADS)</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>lastimport</element>
        <qualifier>loader-ads</qualifier>
        <scope_note>Timestamp of the last import via ADS data loader for publications</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>lastimport</element>
        <qualifier>scopus</qualifier>
        <scope_note>Timestamp of the last import from the Scopus citation database</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>lastimport</element>
        <qualifier>scopus-person</qualifier>
        <scope_note>Timestamp of the last import of author/person data from Scopus</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>lastimport</element>
        <qualifier>scopus-publication</qualifier>
        <scope_note>Timestamp of the last import of publication data from Scopus</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>lastimport</element>
        <qualifier>wos</qualifier>
        <scope_note>Timestamp of the last import from the Web of Science database</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>lastimport</element>
        <qualifier>wos-person</qualifier>
        <scope_note>Timestamp of the last import of author/person data from Web of Science</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>lastimport</element>
        <qualifier>wos-publication</qualifier>
        <scope_note>Timestamp of the last import of publication data from Web of Science</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>lastimport</element>
        <qualifier>loader-pubmed</qualifier>
        <scope_note>Timestamp of the last import via PubMed data loader</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>lastimport</element>
        <qualifier>loader-pubmedeu</qualifier>
        <scope_note>Timestamp of the last import via PubMed Europe data loader</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>lastimport</element>
        <qualifier>loader-scopus</qualifier>
        <scope_note>Timestamp of the last import via Scopus data loader</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>entity</element>
        <qualifier>style</qualifier>
        <scope_note>CSS styling class for entity display customization in the user interface</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>virtual</element>
        <qualifier>journalance</qualifier>
        <scope_note>Virtual metadata field holding journal identifier value derived from linked Journal entity</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>virtualsource</element>
        <qualifier>journalance</qualifier>
        <scope_note>Reference to the source Journal entity UUID for virtual journal metadata</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>curation</element>
        <qualifier>process</qualifier>
        <scope_note>Name of the curation task currently being processed on the item</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>curation</element>
        <qualifier>history</qualifier>
        <scope_note>History log of curation tasks performed on the item with timestamps</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>bitstream</element>
        <qualifier>hasCopies</qualifier>
        <scope_note>Stores the UUID's of the copies of this bitstream</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>bitstream</element>
        <qualifier>isCopyOf</qualifier>
        <scope_note>Stores the UUID of the original copy of this bitstream</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>bitstream</element>
        <qualifier>isReplacedBy</qualifier>
        <scope_note>Stores the UUID of the replacement bitstream</scope_note>
    </dc-type>

    <dc-type>
        <schema>dspace</schema>
        <element>bitstream</element>
        <qualifier>isReplacementOf</qualifier>
        <scope_note>Stores the UUID of the bitstream this replaced</scope_note>
    </dc-type>

</dspace-dc-types>
